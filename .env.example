# DATABASE_URL: PostgreSQL connection string (Render/Local)
DATABASE_URL="postgresql://user:password@localhost:5432/geekhoot"

# JWT_SECRET: Secret for signing tokens
JWT_SECRET="your-super-secret-key"

# CLOUDINARY_URL: For image storage (optional if using placeholders)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# WHATSAPP_ADMIN_NUMBER: International format without symbols (e.g., 919876543210)
WHATSAPP_ADMIN_NUMBER="910000000000"

# GEMINI_API_KEY: Required for AI features
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: For sending registration verification emails
RESEND_API_KEY="re_EHtZbMF8_6iNaPr5eVBJUrvF9Ac1tMKm7"

# ADMIN credentials used by prisma/seed.ts to create the admin account
ADMIN_EMAIL="admin@geekhoot.com"
ADMIN_PASSWORD="your-strong-admin-password"
